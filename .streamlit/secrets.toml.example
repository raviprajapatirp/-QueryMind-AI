# Rename this file to "secrets.toml" (in the same .streamlit/ folder) when
# deploying to Streamlit Community Cloud, and fill in your real key there.
# Do NOT commit your real secrets.toml to git — .streamlit/secrets.toml
# should be in your .gitignore.

GROQ_API_KEY = "your_groq_api_key_here"
APP_SECRET_KEY = "change-this-to-a-random-string"
